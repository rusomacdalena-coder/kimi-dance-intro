---
import Base from '../layouts/Base.astro'
---

<Base title="页面不存在 — 积米律动 Kimidance" description="你访问的页面不存在。">
  <div class="min-h-screen bg-background text-foreground bg-warm-glow flex items-center justify-center px-6">
    <div class="text-center">
      <div class="label-caps mb-6">404</div>
      <h1 class="text-editorial text-4xl sm:text-5xl font-bold mb-6">页面不存在</h1>
      <p class="copy-readable mb-10">这个地址没有内容，回首页看看吧。</p>
      <a
        href="/"
        class="px-8 py-3.5 rounded-full bg-primary text-primary-foreground font-semibold text-base hover:bg-primary/90 transition-colors"
      >
        返回首页
      </a>
    </div>
  </div>
</Base>
