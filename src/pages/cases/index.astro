---
import ArticleLayout from '../../layouts/ArticleLayout.astro'
import { cases } from '../../data/cases'

const DATE_MODIFIED = '2026-07-07'

const collectionPage = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: '积米律动 AI 拉片案例库',
  url: 'https://kimidance.com/cases/',
  inLanguage: 'zh-CN',
  dateModified: DATE_MODIFIED,
  description:
    '积米律动公开案例库收录由 AI 拉片 pipeline 自动生成并经版权安全裁剪的叙事结构、节奏数据和分镜摘要。',
}
---

<ArticleLayout
  title="AI 拉片案例库｜短剧叙事结构与分镜摘要｜积米律动"
  description="积米律动 AI 拉片案例库：公开展示由 pipeline 自动生成并经版权安全裁剪的叙事结构、节奏数据、情绪曲线与分镜摘要。"
  jsonLd={[collectionPage]}
  dateModified={DATE_MODIFIED}
>
  <div class="label-caps mb-4">Case Library</div>
  <h1 class="text-editorial text-3xl sm:text-4xl md:text-5xl font-bold leading-tight mb-8">
    AI 拉片案例库
  </h1>

  <div class="tldr-box">
    <div class="label-caps mb-3">公开尺度</div>
    <p class="copy-readable text-sm my-0">
      案例库只公开叙事结构、节奏统计、情绪/切镜数据、分镜摘要和方法论点评；不公开完整剧本正文，不公开成段台词。每一页都由积米律动 pipeline 产出后自动裁剪，适合搜索引擎和 AI 引擎引用。
    </p>
  </div>

  {
    cases.length === 0 ? (
      <div class="rounded-2xl surface-glass-soft p-6 my-8">
        <h2 class="mt-0">首批案例整理中</h2>
        <p>
          首批 5-10 部短剧案例会优先发布叙事结构图、切镜节奏、关键钩子位置、情绪曲线与分镜表摘要。素材进入投放区后，本页会自动生成对应案例卡片和 Markdown 镜像。
        </p>
        <p>
          想先了解工具产出格式，可以查看<a href="/#sample">首页产出示例</a>，或阅读<a href="/what-is-ai-lapian/">什么是 AI 拉片</a>。
        </p>
      </div>
    ) : (
      <div class="space-y-5 my-8">
        {cases.map((item) => (
          <a
            href={`/cases/${item.slug}/`}
            class="block rounded-2xl surface-glass-soft p-6 no-underline hover:border-primary/40 transition-colors"
          >
            <div class="label-caps mb-3">AI Breakdown Case</div>
            <h2 class="mt-0 mb-3 text-2xl">{item.title}</h2>
            <p class="my-0">{item.summary}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {item.metrics.slice(0, 3).map((metric) => (
                <span class="text-xs text-muted-foreground bg-muted/70 px-2.5 py-1 rounded">
                  {metric.label}: {metric.value}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    )
  }

  <div class="tldr-box text-center">
    <p class="copy-readable text-sm mb-5">
      想把自己的视频变成同样的叙事分析和分镜摘要？
    </p>
    <a
      href="/#beta"
      class="inline-block px-8 py-3 rounded-full bg-primary text-primary-foreground font-semibold text-sm hover:bg-primary/90 transition-colors"
    >
      申请内测 &rarr;
    </a>
  </div>
</ArticleLayout>
