---
import Base from './Base.astro'

interface Props {
  title: string
  description: string
  ogImage?: string
  jsonLd?: Record<string, unknown>[]
  /** ISO date, e.g. 2026-07-05 */
  dateModified?: string
}

const { title, description, ogImage, jsonLd = [], dateModified } = Astro.props

const navLinks = [
  { label: '功能', href: '/#features' },
  { label: '产出示例', href: '/#sample' },
  { label: '什么是 AI 拉片', href: '/what-is-ai-lapian/' },
  { label: '案例库', href: '/cases/' },
  { label: '关于', href: '/about/' },
]
---

<Base title={title} description={description} ogImage={ogImage} ogType="article" jsonLd={jsonLd}>
  <div class="min-h-screen bg-background text-foreground">
    <nav
      class="fixed top-0 inset-x-0 z-50 bg-background/78 backdrop-blur-xl border-b border-border/60"
    >
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5">
          <img src="/logo.png" alt="积米律动" class="w-8 h-8" />
          <div class="flex items-baseline gap-1.5">
            <span class="text-lg font-bold tracking-wide text-cream">积米律动</span>
            <span class="text-xs text-muted-foreground">Kimidance</span>
          </div>
        </a>
        <div class="hidden md:flex items-center gap-8">
          {
            navLinks.map((l) => (
              <a
                href={l.href}
                class="text-sm text-muted-foreground hover:text-cream transition-colors"
              >
                {l.label}
              </a>
            ))
          }
          <a
            href="/#beta"
            class="text-sm font-medium px-5 py-2 rounded-full bg-primary/90 text-primary-foreground hover:bg-primary transition-colors"
          >
            申请内测
          </a>
        </div>
        <a href="/#beta" class="md:hidden text-sm font-medium px-4 py-1.5 rounded-full bg-primary/90 text-primary-foreground">
          申请内测
        </a>
      </div>
    </nav>

    <main class="pt-28 pb-24 px-6 bg-warm-gradient">
      <article class="article-prose">
        <slot />
        {
          dateModified && (
            <p class="text-xs text-muted-foreground/50 mt-14">
              最后更新于 {dateModified}
            </p>
          )
        }
      </article>
    </main>

    <footer class="border-t border-border/40 py-10 px-6">
      <div class="max-w-5xl mx-auto space-y-5">
        <p class="text-xs text-muted-foreground/70 text-center max-w-xl mx-auto leading-relaxed">
          积米律动（Kimidance）是一款 AI
          拉片工具：输入一部短剧或长视频，自动输出文学剧本、叙事节奏分析和分镜速查表，全程台词零篡改。
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-x-6 gap-y-2 text-xs text-muted-foreground"
        >
          <a href="/what-is-ai-lapian/" class="hover:text-cream transition-colors">什么是 AI 拉片</a>
          <a href="/cases/" class="hover:text-cream transition-colors">案例库</a>
          <a href="/about/" class="hover:text-cream transition-colors">关于积米律动</a>
          <a
            href="https://github.com/rusomacdalena-coder/kimi-dance-intro"
            class="hover:text-cream transition-colors"
            rel="noopener"
          >
            GitHub
          </a>
          <a href="mailto:oliverzhu929598@gmail.com" class="hover:text-cream transition-colors">
            oliverzhu929598@gmail.com
          </a>
        </div>
        <div class="text-xs text-muted-foreground/50 text-center">
          &copy; 2026 积米律动 &middot; Kimidance
        </div>
      </div>
    </footer>
  </div>
</Base>
